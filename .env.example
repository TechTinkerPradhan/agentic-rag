# Copy this file to .env and fill in your keys

# OpenAI — required for LLM enrichment, planning, synthesis, and evaluation
OPENAI_API_KEY=sk-...

# Google Gemini — optional alternative LLM
GOOGLE_API_KEY=AIza...

# W&B Weave — required for tracing
WANDB_API_KEY=...
WANDB_PROJECT=agentic-rag

# LangSmith — optional LangChain tracing
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_TRACING_V2=true

# Tavily — required for web search (Scout tool)
TAVILY_API_KEY=tvly-...
